(let range (lambda (a b)
    (if (> a b)
     NIL
     (cons a (range (+ a 1) b)))))

(let map (lambda (f l) 
    (if (nil? l)
     NIL
     (cons (f (car l)) (map f (cdr l))))))

(let double (lambda (x) (+ x x)))
(let const (lambda (x) (lambda (n) x)))
(print (range 7 41))
(print (map double (range 5 11)))
(print (map (const 7) (range 101 108)))

